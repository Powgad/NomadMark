<?xml version="1.0" encoding="utf-8"?>
<!--
    Markdown Editor Layout - 重构版本

    新架构：独立层级设计
    - 编辑层：独立层，包含 EditText，支持光标和键盘编辑
    - 预览层：独立层，显示渲染后的 Markdown，只读
    - 分屏层：独立层，上半区预览+下半区编辑
    - 手势层：覆盖层，修订模式启用手势识别

    层切换规则：
    1. 编辑模式：只显示编辑层
    2. 预览模式：只显示预览层
    3. 分屏模式：只显示分屏层
    4. 修订模式：显示对应模式层 + 手势层
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 顶部工具栏 (始终显示) -->
    <LinearLayout
        android:id="@+id/toolbar_top"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:background="#F5F5F5"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical">

        <!-- 1. 返回按钮 -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="返回"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 2. 目录按钮 -->
        <ImageButton
            android:id="@+id/btn_toc"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_toc"
            android:contentDescription="目录"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 3. 文件名显示 -->
        <TextView
            android:id="@+id/text_filename"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="未命名.md"
            android:textSize="15sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:ellipsize="end"
            android:singleLine="true"
            android:gravity="center" />

        <!-- 4. 预览/编辑切换按钮 -->
        <ImageButton
            android:id="@+id/btn_preview_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_preview_off"
            android:contentDescription="预览"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 5. 修订按钮 -->
        <ImageButton
            android:id="@+id/btn_revision"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_revision"
            android:contentDescription="修订"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 6. 搜索按钮 -->
        <ImageButton
            android:id="@+id/btn_search"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_search"
            android:contentDescription="搜索"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 7. 分屏/全屏切换按钮 -->
        <ImageButton
            android:id="@+id/btn_split"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_split_off"
            android:contentDescription="分屏"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 8. 撤销按钮 -->
        <ImageButton
            android:id="@+id/btn_undo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_undo"
            android:contentDescription="撤销"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 9. 重做按钮 -->
        <ImageButton
            android:id="@+id/btn_redo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_redo"
            android:contentDescription="重做"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 10. 快捷栏按钮 -->
        <ImageButton
            android:id="@+id/btn_toolbar_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_toolbar"
            android:contentDescription="快捷栏"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 11. 按键组合设置按钮 -->
        <ImageButton
            android:id="@+id/btn_keyboard_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_keyboard_settings"
            android:contentDescription="按键设置"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- 12. 保存按钮 -->
        <ImageButton
            android:id="@+id/btn_save"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_save"
            android:contentDescription="保存"
            android:scaleType="centerInside"
            android:padding="8dp" />
    </LinearLayout>

    <!-- 搜索栏 (默认隐藏) -->
    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/toolbar_top"
        android:orientation="vertical"
        android:background="#EEEEEE"
        android:padding="8dp"
        android:visibility="gone">

        <!-- 搜索输入行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/search_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="搜索..."
                android:background="@drawable/search_input_bg"
                android:padding="8dp"
                android:singleLine="true"
                android:inputType="text"
                android:imeOptions="actionSearch" />

            <ImageButton
                android:id="@+id/btn_search_single"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_search_single"
                android:contentDescription="单个搜索" />

            <ImageButton
                android:id="@+id/btn_search_all"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_search_all"
                android:contentDescription="全部搜索" />

            <ImageButton
                android:id="@+id/btn_search_prev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_up"
                android:contentDescription="上一个" />

            <ImageButton
                android:id="@+id/btn_search_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_down"
                android:contentDescription="下一个" />

            <ImageButton
                android:id="@+id/btn_search_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:contentDescription="关闭" />
        </LinearLayout>

        <!-- 替换输入行 (默认隐藏) -->
        <LinearLayout
            android:id="@+id/replace_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/replace_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="替换为..."
                android:background="@drawable/search_input_bg"
                android:padding="8dp"
                android:singleLine="true"
                android:inputType="text" />

            <Button
                android:id="@+id/btn_replace_one"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="替换一个"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_replace_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="全部替换"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- =========================================================================
         主内容区域 - 独立层级架构
         ========================================================================= -->

    <!-- 层1：编辑层 (EditorLayer) - 独立层，默认显示 -->
    <!-- 包含 EditText，支持光标和键盘编辑 -->
    <ScrollView
        android:id="@+id/editor_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/search_bar"
        android:fillViewport="true"
        android:background="#FFFFFF">

        <EditText
            android:id="@+id/editor_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:padding="16dp"
            android:textSize="16sp"
            android:textColor="#000000"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:hint="# 开始输入您的 Markdown 内容..."
            android:lineSpacingExtra="4dp" />
    </ScrollView>

    <!-- 层2：预览层 (PreviewLayer) - 独立层，默认隐藏 -->
    <!-- 显示渲染后的 Markdown，只读，无光标 -->
    <ScrollView
        android:id="@+id/preview_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/search_bar"
        android:fillViewport="true"
        android:background="#FFFFFF"
        android:visibility="gone">

        <TextView
            android:id="@+id/preview_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textSize="16sp"
            android:textColor="#000000"
            android:lineSpacingExtra="4dp"
            android:focusable="false"
            android:focusableInTouchMode="false" />
    </ScrollView>

    <!-- 层3：分屏层 (SplitViewLayer) - 独立层，默认隐藏 -->
    <!-- 上半区预览 + 下半区编辑，内容同步，仅编辑区有光标 -->
    <LinearLayout
        android:id="@+id/split_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/search_bar"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- 上半区：预览区 -->
        <com.editor.nomadmark.ObservableScrollView
            android:id="@+id/split_preview_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="6"
            android:background="#FAFAFA"
            android:fillViewport="true">

            <TextView
                android:id="@+id/split_preview_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="#333333"
                android:focusable="false"
                android:focusableInTouchMode="false" />
        </com.editor.nomadmark.ObservableScrollView>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC" />

        <!-- 下半区：编辑区 -->
        <com.editor.nomadmark.ObservableScrollView
            android:id="@+id/split_editor_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:background="#FFFFFF"
            android:fillViewport="true">

            <EditText
                android:id="@+id/split_editor_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="#000000"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:hint="编辑内容..."
                android:lineSpacingExtra="2dp" />
        </com.editor.nomadmark.ObservableScrollView>
    </LinearLayout>

    <!-- 层4：手势层 (GestureLayer) - 覆盖层，默认隐藏 -->
    <!-- 修订模式启用手势识别，根据触摸位置判断操作区域 -->
    <com.editor.nomadmark.GestureOverlayView
        android:id="@+id/gesture_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/search_bar"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false" />

    <!-- 底部快捷栏 (默认隐藏) -->
    <HorizontalScrollView
        android:id="@+id/toolbar_bottom"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_toolbar_height"
        android:layout_alignParentBottom="true"
        android:background="#F0F0F0"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 加粗 -->
            <Button
                android:id="@+id/btn_bold"
                style="@style/ToolbarButton"
                android:text="**B**" />

            <!-- 斜体 -->
            <Button
                android:id="@+id/btn_italic"
                style="@style/ToolbarButton"
                android:text="*I*" />

            <!-- 标题加大 -->
            <Button
                android:id="@+id/btn_heading_up"
                style="@style/ToolbarButton"
                android:text="H+" />

            <!-- 标题减小 -->
            <Button
                android:id="@+id/btn_heading_down"
                style="@style/ToolbarButton"
                android:text="H-" />

            <!-- 行内代码 -->
            <Button
                android:id="@+id/btn_code_inline"
                style="@style/ToolbarButton"
                android:text="`代码`" />

            <!-- 代码块 -->
            <Button
                android:id="@+id/btn_code_block"
                style="@style/ToolbarButton"
                android:text="```" />

            <!-- 链接 -->
            <Button
                android:id="@+id/btn_link"
                style="@style/ToolbarButton"
                android:text="链接" />

            <!-- 列表 -->
            <Button
                android:id="@+id/btn_list"
                style="@style/ToolbarButton"
                android:text="- 列表" />

            <!-- 引用 -->
            <Button
                android:id="@+id/btn_quote"
                style="@style/ToolbarButton"
                android:text="> 引用" />

            <!-- 表格 -->
            <Button
                android:id="@+id/btn_table"
                style="@style/ToolbarButton"
                android:text="表格" />

            <!-- 分隔线 -->
            <Button
                android:id="@+id/btn_hr"
                style="@style/ToolbarButton"
                android:text="---" />

            <!-- 数学公式 -->
            <Button
                android:id="@+id/btn_formula"
                style="@style/ToolbarButton"
                android:text="∑" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 目录侧边栏 (默认隐藏) -->
    <FrameLayout
        android:id="@+id/toc_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar_top"
        android:background="#AAFFFFFF"
        android:visibility="gone">

        <!-- 目录内容 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- 目录列表 (占2/3) -->
            <ListView
                android:id="@+id/toc_list"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:background="#FFFFFF"
                android:padding="8dp" />

            <!-- 竖分隔线 -->
            <View
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:background="#000000" />

            <!-- 空白区域 (占1/3，点击关闭目录) -->
            <View
                android:id="@+id/toc_close_area"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#AAFFFFFF" />
        </LinearLayout>
    </FrameLayout>

    <!-- 外接键盘标识 (底部) -->
    <TextView
        android:id="@+id/keyboard_indicator"
        android:layout_width="match_parent"
        android:layout_height="@dimen/keyboard_indicator_height"
        android:layout_alignParentBottom="true"
        android:background="#DDDDDD"
        android:text="⌨ 外接键盘"
        android:textColor="#666666"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone" />

</RelativeLayout>
